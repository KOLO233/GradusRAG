# RefraRAG 配置文件
# 复制此文件为 settings.yaml 并填入你的实际配置
# cp config/settings.yaml.example config/settings.yaml

# =============================================================================
# LLM 配置
# =============================================================================
llm:
  provider: "openai"           # openai / azure / ollama / deepseek
  model: "gpt-4o"
  temperature: 0.0
  max_tokens: 4096
  api_key: "YOUR_API_KEY_HERE"
  base_url: ""                 # Ollama: http://localhost:11434/v1
                               # DeepSeek: https://api.deepseek.com/v1
                               # Azure: 留空，使用 azure_endpoint

# =============================================================================
# 嵌入模型配置
# =============================================================================
embedding:
  provider: "local"            # local / api
  model: "BAAI/bge-m3"         # 本地模型名或 API 模型名
  dimensions: 1024             # bge-m3: 1024, bge-small-zh: 512
  device: "cpu"                # cpu / cuda
  api_key: ""                  # api 模式时填写
  api_base_url: ""             # api 模式时填写

# =============================================================================
# 向量数据库配置
# =============================================================================
vector_store:
  provider: "milvus"           # milvus / chroma
  host: "127.0.0.1"
  port: 19530
  collection: "refrarag"
  persist_directory: "./data/db/chroma"

# =============================================================================
# 检索配置
# =============================================================================
retrieval:
  dense_top_k: 20
  sparse_top_k: 20
  fusion_top_k: 10
  rrf_k: 60

# =============================================================================
# 重排序配置
# =============================================================================
rerank:
  enabled: true
  provider: "cross_encoder"    # cross_encoder / llm
  model: "BAAI/bge-reranker-v2-m3"
  top_k: 5

# =============================================================================
# 文档摄取配置
# =============================================================================
ingestion:
  chunk_size_l1: 2500
  chunk_size_l2: 1024
  chunk_size_l3: 512
  chunk_overlap: 100
  splitter: "recursive"

# =============================================================================
# 查询分类器配置
# =============================================================================
query_classifier:
  mode: "hybrid"               # rule / llm / hybrid
  llm_threshold: 0.7

# =============================================================================
# 知识图谱配置
# =============================================================================
graph:
  enabled: true
  storage: "networkx"          # networkx / neo4j
  entity_types:
    - "疾病"
    - "药物"
    - "症状"
    - "概念"
    - "人物"
    - "组织"
    - "技术"
    - "方法"
  max_hops: 3

# =============================================================================
# 生成策略配置
# =============================================================================
generation:
  l1_strategy: "direct"
  l2_strategy: "structured_cot"
  l3_strategy: "expert_cot"
  l4_strategy: "self_rag"
  max_self_rag_iterations: 3

# =============================================================================
# 评估配置
# =============================================================================
evaluation:
  enabled: true
  framework: "custom"
  metrics:
    - "hit_rate"
    - "mrr"
    - "faithfulness"
    - "relevancy"
    - "classification_accuracy"

# =============================================================================
# 可观测性配置
# =============================================================================
observability:
  log_level: "INFO"
  trace_enabled: true
  trace_file: "./logs/traces.jsonl"
